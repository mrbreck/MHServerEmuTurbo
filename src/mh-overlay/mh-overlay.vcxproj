<?xml version="1.0" encoding="utf-8"?>
<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <ItemGroup Label="ProjectConfigurations">
    <ProjectConfiguration Include="Release|x64">
      <Configuration>Release</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
  </ItemGroup>

  <PropertyGroup Label="Globals">
    <ProjectGuid>{A1B2C3D4-E5F6-7890-ABCD-EF1234567890}</ProjectGuid>
    <Keyword>Win32Proj</Keyword>
    <RootNamespace>mh-overlay</RootNamespace>
    <WindowsTargetPlatformVersion>10.0</WindowsTargetPlatformVersion>
  </PropertyGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.Default.props" />

  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|x64'" Label="Configuration">
    <ConfigurationType>DynamicLibrary</ConfigurationType>
    <UseDebugLibraries>false</UseDebugLibraries>
    <PlatformToolset>v145</PlatformToolset>
    <CharacterSet>Unicode</CharacterSet>
    <WholeProgramOptimization>true</WholeProgramOptimization>
  </PropertyGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.props" />

  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|x64'">
    <OutDir>$(SolutionDir)build\</OutDir>
    <IntDir>$(SolutionDir)obj\$(Configuration)\</IntDir>
    <TargetName>dinput8</TargetName>
  </PropertyGroup>

  <ItemDefinitionGroup Condition="'$(Configuration)|$(Platform)'=='Release|x64'">
    <ClCompile>
      <WarningLevel>Level3</WarningLevel>
      <Optimization>MaxSpeed</Optimization>
      <FunctionLevelLinking>true</FunctionLevelLinking>
      <IntrinsicFunctions>true</IntrinsicFunctions>
      <PreprocessorDefinitions>NDEBUG;_WINDOWS;_USRDLL;%(PreprocessorDefinitions)</PreprocessorDefinitions>
      <!-- deps\imgui  = imgui root (contains imgui.h)                      -->
      <!-- deps\imgui\backends = imgui_impl_dx11.h / imgui_impl_win32.h     -->
      <!-- deps\minhook\include = MinHook.h                                 -->
      <AdditionalIncludeDirectories>
        $(ProjectDir)deps\imgui;$(ProjectDir)deps\imgui\backends;$(ProjectDir)deps\minhook\include;%(AdditionalIncludeDirectories)
      </AdditionalIncludeDirectories>
      <RuntimeLibrary>MultiThreaded</RuntimeLibrary>
      <ExceptionHandling>Sync</ExceptionHandling>
    </ClCompile>
    <Link>
      <SubSystem>Windows</SubSystem>
      <EnableCOMDATFolding>true</EnableCOMDATFolding>
      <OptimizeReferences>true</OptimizeReferences>
      <ModuleDefinitionFile>$(ProjectDir)src\dinput8.def</ModuleDefinitionFile>
      <AdditionalDependencies>d3d9.lib;winhttp.lib;wininet.lib;%(AdditionalDependencies)</AdditionalDependencies>
      <!-- MinHook static lib — built from deps\minhook -->
      <AdditionalLibraryDirectories>
        $(ProjectDir)deps\minhook\build\$(Configuration);%(AdditionalLibraryDirectories)
      </AdditionalLibraryDirectories>
    </Link>
  </ItemDefinitionGroup>

  <ItemGroup>
    <ClCompile Include="src\dllmain.cpp" />
    <ClCompile Include="src\auth.cpp" />
    <ClCompile Include="src\api_client.cpp" />
    <ClCompile Include="src\overlay.cpp" />
    <ClCompile Include="src\dinput8_proxy.cpp" />
    <!-- ImGui core -->
    <ClCompile Include="deps\imgui\imgui.cpp" />
    <ClCompile Include="deps\imgui\imgui_draw.cpp" />
    <ClCompile Include="deps\imgui\imgui_tables.cpp" />
    <ClCompile Include="deps\imgui\imgui_widgets.cpp" />
    <ClCompile Include="deps\imgui\backends\imgui_impl_dx9.cpp" />
    <ClCompile Include="deps\imgui\backends\imgui_impl_win32.cpp" />
    <!-- MinHook (compiled from source so no separate lib needed) -->
    <ClCompile Include="deps\minhook\src\buffer.c" />
    <ClCompile Include="deps\minhook\src\hook.c" />
    <ClCompile Include="deps\minhook\src\trampoline.c" />
    <ClCompile Include="deps\minhook\src\hde\hde64.c" />
  </ItemGroup>

  <ItemGroup>
    <ClInclude Include="src\auth.h" />
    <ClInclude Include="src\api_client.h" />
    <ClInclude Include="src\overlay.h" />
    <ClInclude Include="src\dinput8_proxy.h" />
  </ItemGroup>

  <ItemGroup>
    <None Include="src\dinput8.def" />
  </ItemGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.targets" />
</Project>
